{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "script=$(find ~/.claude/plugins/marketplaces -path '*/claude-tracker/scripts/claude-tracker-session-start.sh' 2>/dev/null | head -1) && [ -f \"$script\" ] && bash \"$script\" || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "script=$(find ~/.claude/plugins/marketplaces -path '*/claude-tracker/scripts/claude-tracker-stop.sh' 2>/dev/null | head -1) && [ -f \"$script\" ] && bash \"$script\" || true"
          }
        ]
      }
    ]
  }
}
